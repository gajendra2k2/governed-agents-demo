# Copy to .env and edit for your setup.

# Anthropic API key. REQUIRED for the live agent run (`make agent`).
# Get one at https://console.anthropic.com/. Not needed for `make agent-replay`.
ANTHROPIC_API_KEY=

# Kafka bootstrap. Default matches docker-compose.yml.
KAFKA_BOOTSTRAP=localhost:9092

# MCP server.
MCP_HOST=127.0.0.1
MCP_PORT=8000

# Where the SQLite state file lives (approvals + order ledger).
STATE_DIR=./state

# Legacy: only used by the multi-model routing tool's offline canned-response path.
OFFLINE_MODE=false
